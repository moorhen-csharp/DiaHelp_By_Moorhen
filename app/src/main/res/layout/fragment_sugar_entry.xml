<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" >
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="16dp" android:paddingBottom="32dp">
        <!--  Заголовок  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Уровень сахара" android:textSize="26sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Введите показание глюкометра" android:textSize="14sp" android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="20dp"/>
        <!--  Главная карточка: дисплей ввода  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="24dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/color_button">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ммоль/л" android:textSize="13sp" android:textColor="#B3FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputSugarLevel" android:layout_width="200dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textAlignment="center" android:textSize="52sp" android:textStyle="bold" android:textColor="#FFFFFF" android:hint="—" android:textColorHint="#80FFFFFF" android:background="@null" android:padding="0dp"/>
                <View android:layout_width="120dp" android:layout_height="2dp" android:background="#80FFFFFF" android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNotMeasured" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Не измерял" android:textColor="#FFFFFF" app:strokeColor="#80FFFFFF" app:strokeWidth="1.5dp" app:cornerRadius="20dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Карточка: Когда измерено  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="?attr/colorOutline" app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🕐 Когда измерено" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>
                </LinearLayout>
                <com.google.android.material.chip.ChipGroup android:id="@+id/chipSugarType" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" app:selectionRequired="true">
                    <com.google.android.material.chip.Chip android:id="@+id/chipEmpty" style="@style/Widget.Material3.Chip.Filter" android:text="🌅 Натощак" android:checkable="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipBefore" style="@style/Widget.Material3.Chip.Filter" android:text="🍽 До еды" android:checkable="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipAfter" style="@style/Widget.Material3.Chip.Filter" android:text="✅ После еды" android:checkable="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipNight" style="@style/Widget.Material3.Chip.Filter" android:text="🌙 До сна" android:checkable="true" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Карточка: Самочувствие  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="?attr/colorOutline" app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💚 Самочувствие" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:layout_marginBottom="12dp"/>
                <com.google.android.material.chip.ChipGroup android:id="@+id/chipHealth" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" app:selectionRequired="true">
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊 Отличное" android:checkable="true"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🙂 Хорошее" android:checkable="true"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😐 Среднее" android:checkable="true"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😟 Плохое" android:checkable="true"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Карточка: Инсулин  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="?attr/colorOutline" app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💉 Доза инсулина" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:layout_marginBottom="12dp"/>
                <com.google.android.material.textfield.TextInputLayout  android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Доза (единицы)" app:suffixText="ед" app:boxCornerRadiusTopStart="14dp" app:boxCornerRadiusTopEnd="14dp" app:boxCornerRadiusBottomStart="14dp" app:boxCornerRadiusBottomEnd="14dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputInsulin" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textAlignment="center" android:textSize="20sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Кнопка Сохранить  -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="56dp" android:text="Сохранить запись" android:textSize="16sp" android:textStyle="bold" app:cornerRadius="16dp" app:backgroundTint="@color/color_button" android:textColor="@color/color_text_button" app:icon="@drawable/ic_save" app:iconGravity="textStart" app:iconPadding="8dp"/>
    </LinearLayout>
</ScrollView>