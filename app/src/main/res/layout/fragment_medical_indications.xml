<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent"  android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="16dp" android:paddingBottom="32dp">
        <!--  Заголовок  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Медицинские анализы" android:textSize="26sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Выберите категорию анализов" android:textSize="14sp" android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="24dp"/>
        <!--  Анализы крови  -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/bloodAnalysis" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp" android:clickable="true" android:focusable="true" app:cardCornerRadius="20dp" app:cardElevation="2dp" app:cardBackgroundColor="#E3F2FD">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                <TextView android:layout_width="56dp" android:layout_height="56dp" android:text="🩸" android:textSize="28sp" android:gravity="center" android:background="#BBDEFB" android:padding="8dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Анализ крови" android:textSize="17sp" android:textStyle="bold" android:textColor="#0D47A1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HbA1c, C-пептид, гемоглобин" android:textSize="13sp" android:textColor="#1565C0" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="#1565C0"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Липидный профиль  -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/lipidsAnalysis" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp" android:clickable="true" android:focusable="true" app:cardCornerRadius="20dp" app:cardElevation="2dp" app:cardBackgroundColor="#F3E5F5">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                <TextView android:layout_width="56dp" android:layout_height="56dp" android:text="💊" android:textSize="28sp" android:gravity="center" android:background="#E1BEE7" android:padding="8dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Липидный профиль" android:textSize="17sp" android:textStyle="bold" android:textColor="#4A148C"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Холестерин, ЛПВП, ЛПНП" android:textSize="13sp" android:textColor="#6A1B9A" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="#6A1B9A"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Биохимия  -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/biochemAnalysis" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp" android:clickable="true" android:focusable="true" app:cardCornerRadius="20dp" app:cardElevation="2dp" app:cardBackgroundColor="#E8F5E9">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                <TextView android:layout_width="56dp" android:layout_height="56dp" android:text="🔬" android:textSize="28sp" android:gravity="center" android:background="#C8E6C9" android:padding="8dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Биохимия" android:textSize="17sp" android:textStyle="bold" android:textColor="#1B5E20"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Креатинин, мочевина, АЛТ/АСТ" android:textSize="13sp" android:textColor="#2E7D32" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="#2E7D32"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  Гормоны (заготовка)  -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/hormonesAnalysis" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp" android:clickable="true" android:focusable="true" app:cardCornerRadius="20dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFF3E0">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                <TextView android:layout_width="56dp" android:layout_height="56dp" android:text="⚗️" android:textSize="28sp" android:gravity="center" android:background="#FFE0B2" android:padding="8dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Гормоны" android:textSize="17sp" android:textStyle="bold" android:textColor="#E65100"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" • скоро" android:textSize="12sp" android:textColor="#FF8F00"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Тиреоидная функция и другие" android:textSize="13sp" android:textColor="#BF360C" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="#BF360C"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>